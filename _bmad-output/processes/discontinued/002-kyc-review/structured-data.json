  "metadata": {
    "purpose": "Ensure regulatory compliance by verifying client identity, assessing risk profiles, and maintaining up-to-date documentation",
    "trigger": "Periodic review cycle, event-driven trigger, or new client onboarding",
    "frequency": "Ongoing — periodic (1yr/3yr) and event-driven",
    "volume": "~2,400 reviews/year (~200/month)"
  },
  "process_overview": {
    "process_owner": "Head of KYC Operations",
    "regulatory_domain": "AML/CFT, FATF, Local Banking Regulations",
    "annual_volume": 2400,
    "monthly_average": 200,
